<mvc:View controllerName="com.clientname.b70sapui5.controller.View2"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="idPageTitleBtn2" title="I am View 2- Getter and Setter" showNavButton="true" navButtonPress="onButtonPress2">
        <content>
            <!-- <HBox id="hbox2" width="100%"> -->
                <Text id="idTxtWelcome" text="Welcome to SAP UI5" textAlign="Center" width="100%" class="sapMH1FontSize"></Text>
                <Label id="idLblName" text="Enter your name" required="true" class="myTextFontSize"></Label>
                <Input id="idIpName" width="30%" maxLength="10" value="" class="sapUiSmallMarginEnd sapUiSmallMarginBegin"></Input>
                <Button id="idBtnSubmit" text="Button Styles" type="Emphasized" press="onSubmit"></Button>
            <!-- </HBox> -->
        </content>
        <footer>
			<OverflowToolbar>
				<ToolbarSpacer/>
				<Button text="Accept" type="Accept" />
				<Button text="Reject" type="Reject" />
				<Button text="Edit" />
				<Button text="Delete" />
                <Button text="Next" type="Emphasized" press="onNextPage3" />
			</OverflowToolbar>
		</footer>
    </Page>
</mvc:View>